# =============================================================================
# AI_PM Project - Git Ignore Configuration
# =============================================================================

# Git worktrees
.worktrees/

# -----------------------------------------------------------------------------
# Operating System Files
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db
Desktop.ini

# -----------------------------------------------------------------------------
# IDE & Editor Files
# -----------------------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*~

# -----------------------------------------------------------------------------
# Logs & Temporary Files
# -----------------------------------------------------------------------------
*.log
logs/
tmp/
temp/
*.tmp
*.temp
.cache/

# -----------------------------------------------------------------------------
# AI_PM Specific - Generated Content
# -----------------------------------------------------------------------------

# Project outputs (may contain sensitive corporate data)
output/

# Presentation files (local use only)
AI_PM_提效分享.html

# Documentation build output
.docs/

# Session planning documents (generated by AI sessions, not for version control)
docs/

# Playwright
.playwright/
.playwright-mcp/
.claude/**/.playwright-cli/
.claude/projects/

# -----------------------------------------------------------------------------
# AI_PM Specific - Templates (Keep examples, ignore user uploads)
# -----------------------------------------------------------------------------

# Configs - only keep reference config
templates/configs/*.md
!templates/configs/reference-config.md

# Knowledge base - contains internal business data, school names, product strategy
templates/knowledge-base/

# PRD Styles - keep default and examples
templates/prd-styles/*/
!templates/prd-styles/default/
!templates/prd-styles/example-*/
!templates/prd-styles/README.md

# UI Specs - keep examples
templates/ui-specs/*/
!templates/ui-specs/example-*/
!templates/ui-specs/README.md

# -----------------------------------------------------------------------------
# Design Source Files (Large & Proprietary)
# -----------------------------------------------------------------------------
*.sketch
*.fig
*.ai
*.psd
*.xd

# -----------------------------------------------------------------------------
# Archives
# -----------------------------------------------------------------------------
*.zip
*.rar
*.7z
*.tar.gz

# -----------------------------------------------------------------------------
# Language Specific
# -----------------------------------------------------------------------------

# Node.js
node_modules/
package-lock.json
!app/package-lock.json
yarn.lock

# Tauri app
app/node_modules/
app/dist/
app/src-tauri/target/

# Python
__pycache__/
*.pyc
*.pyo
venv/
.env
