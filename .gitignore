# -----------------------------------------------------------------------------
*.log
logs/
tmp/
temp/
*.tmp
*.temp
.cache/
.turbo/
.vite/
*.tsbuildinfo

# -----------------------------------------------------------------------------
# AI_PM Specific - Generated Content
# -----------------------------------------------------------------------------

# Project outputs (may contain sensitive corporate data)
output/

# Presentation files (local use only)
AI_PM_提效分享.html

# Documentation build output
.docs/

# Session planning documents (generated by AI sessions, not for version control)
/docs/plans/
/app/docs/plans/

# Playwright
.playwright/
.playwright-mcp/
.claude/**/.playwright-cli/
.claude/projects/
.claude/settings.local.json
.codex/

# Test reports
coverage/
.nyc_output/
playwright-report/
test-results/

# -----------------------------------------------------------------------------
# AI_PM Specific - Templates
# -----------------------------------------------------------------------------

# Built-in templates are versioned. Keep local uploads/private overrides out.
templates/**/local/
templates/**/private/
templates/**/uploads/
templates/**/.cache/

