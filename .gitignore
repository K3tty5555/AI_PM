# =============================================================================
# AI_PM Project - Git Ignore Configuration
# =============================================================================

# Git worktrees
.worktrees/

# -----------------------------------------------------------------------------
# Operating System Files
# -----------------------------------------------------------------------------
.DS_Store
._*
.Spotlight-V100/
.Trashes/
Thumbs.db
Desktop.ini

# -----------------------------------------------------------------------------
# IDE & Editor Files
# -----------------------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*~

# -----------------------------------------------------------------------------
# Logs & Temporary Files
# -----------------------------------------------------------------------------
*.log
logs/
tmp/
temp/
*.tmp
*.temp
.cache/
.turbo/
.vite/
*.tsbuildinfo

# -----------------------------------------------------------------------------
# AI_PM Specific - Generated Content
# -----------------------------------------------------------------------------

# Project outputs (may contain sensitive corporate data)
output/

# Presentation files (local use only)
AI_PM_提效分享.html

# Documentation build output
.docs/

# Documentation directory (含真实业务背景、对接人、试点学校等私有信息)
# 包括 plans/ 和顶层设计文档；后续在 docs/ 下新增的文件也会自动 ignore
/docs/
/app/docs/plans/

# AI shared local context copies
# Keep bridge docs/scripts versioned, but do not upload local memory snapshots
# or raw/summarized AI conversation records.
.ai-shared/memory-snapshots/
.ai-shared/conversations/
.ai-shared/memory-index.md
.ai-shared/agent-index.md
.ai-shared/skill-index.md

# Playwright
.playwright/
.playwright-mcp/
.claude/**/.playwright-cli/
.claude/projects/
.claude/settings.local.json
.codex/

# Test reports
coverage/
.nyc_output/
playwright-report/
test-results/

# -----------------------------------------------------------------------------
# AI_PM Specific - Templates
# -----------------------------------------------------------------------------

# Built-in templates are versioned. Keep local uploads/private overrides out.
templates/**/local/
templates/**/private/
templates/**/uploads/
templates/**/.cache/

# 个人知识库内容（含真实业务洞察、客户访谈、PRD 引用等私有信息）
# 保留 README.md（目录说明）和 .gitkeep（目录骨架）
templates/knowledge-base/decisions/*
templates/knowledge-base/insights/*
templates/knowledge-base/metrics/*
templates/knowledge-base/patterns/*
templates/knowledge-base/pitfalls/*
templates/knowledge-base/playbooks/*
!templates/knowledge-base/**/.gitkeep

# -----------------------------------------------------------------------------
# Design Source Files (Large & Proprietary)
# -----------------------------------------------------------------------------
*.sketch
*.fig
*.ai
*.psd
*.xd

# -----------------------------------------------------------------------------
# Archives
# -----------------------------------------------------------------------------
*.zip
*.rar
*.7z
*.tar.gz

# -----------------------------------------------------------------------------
# Language Specific
# -----------------------------------------------------------------------------

# Node.js
node_modules/
package-lock.json
!app/package-lock.json
yarn.lock
.pnpm-store/

# Tauri app
app/node_modules/
app/dist/
app/src-tauri/target/

# Python
__pycache__/
*.pyc
*.pyo
venv/
.venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.env
.env.*
!.env.example
!.env.*.example
.envrc
AI_PM/

# Local databases
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite-shm
*.sqlite-wal
*.sqlite3
