{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AI PM",
  "version": "0.5.2",
  "identifier": "com.ai-pm.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "AI PM",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "decorations": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": [
      "resources/plaza-manifest.json",
      "resources/skills/**/*",
      "resources/templates/**/*"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDk3QUNEOTBDRTA3NDI4N0MKUldSOEtIVGdETm1zbDh0ZFZJalVXalRiZmpheGdSK2NxMkRaWFJ0UVFITE9HcUFiWUkvRFpQRGkK",
      "endpoints": [
        "https://K3tty5555.github.io/AI_PM/latest.json"
      ]
    }
  }
}
