{
  "version": "2.0",
  "description": "AI_PM 流水线配置 - Phase 流程的唯一事实来源 (Single Source of Truth)",

  "phases": [
    {
      "id": "reference",
      "order": 0,
      "name": "参考资源收集",
      "description": "收集参考资料（URL/图片/竞品），使用 playwright MCP 抓取网页",
      "skill": "ai-pm",
      "output": ["00-reference-analysis.md", "07-references/"],
      "confirm": false,
      "optional": false,
      "silent": false
    },
    {
      "id": "requirement",
      "order": 1,
      "name": "需求澄清",
      "description": "交互式访谈，挖掘需求本质，生成需求草案",
      "skill": "ai-pm",
      "entryModes": ["direct", "interview", "data-insight"],
      "output": ["01-requirement-draft.md"],
      "confirm": false,
      "optional": false,
      "silent": false
    },
    {
      "id": "analysis",
      "order": 2,
      "name": "需求分析",
      "description": "深入分析需求，输出目标用户、痛点、功能范围、优先级",
      "skill": "ai-pm-analyze",
      "input": ["01-requirement-draft.md"],
      "output": ["02-analysis-report.md"],
      "confirm": false,
      "optional": false,
      "silent": true
    },
    {
      "id": "research",
      "order": 3,
      "name": "竞品研究",
      "description": "分析同类产品优劣势，输出竞品对比和差异化机会",
      "skill": "ai-pm-research",
      "input": ["01-requirement-draft.md", "02-analysis-report.md"],
      "output": ["03-competitor-report.md"],
      "confirm": false,
      "optional": false,
      "silent": true
    },
    {
      "id": "story",
      "order": 4,
      "name": "用户故事",
      "description": "编写用户故事和用例，包括验收标准",
      "skill": "ai-pm-story",
      "input": ["02-analysis-report.md"],
      "output": ["04-user-stories.md"],
      "confirm": false,
      "optional": false,
      "silent": true
    },
    {
      "id": "prd",
      "order": 5,
      "name": "PRD 生成",
      "description": "整合前序阶段产出，生成完整 PRD 文档",
      "skill": "ai-pm-prd",
      "input": ["02-analysis-report.md", "03-competitor-report.md", "04-user-stories.md"],
      "output": ["05-prd/05-PRD-v1.0.md"],
      "confirm": true,
      "gate": true,
      "gateActions": ["选择写作风格", "选择设计规范", "确认核心结论"],
      "optional": false,
      "silent": false
    },
    {
      "id": "analytics",
      "order": 6,
      "name": "数据埋点设计",
      "description": "设计指标体系、埋点方案、数据看板、A/B 测试",
      "skill": "ai-pm-data",
      "input": ["05-prd/05-PRD-v1.0.md"],
      "output": ["09-analytics-requirement.md"],
      "confirm": true,
      "optional": true,
      "silent": false
    },
    {
      "id": "prototype",
      "order": 7,
      "name": "原型生成",
      "description": "生成可交互 HTML 原型，支持 Web/移动端/响应式",
      "skill": "ai-pm-prototype",
      "input": ["05-prd/05-PRD-v1.0.md", "09-analytics-requirement.md"],
      "output": ["06-prototype/"],
      "confirm": true,
      "tokenWarning": true,
      "optional": true,
      "silent": false
    },
    {
      "id": "review",
      "order": 8,
      "name": "需求评审",
      "description": "九角色模拟评审会议，多轮迭代直到方案成熟",
      "skill": "ai-pm-review",
      "input": ["05-prd/05-PRD-v1.0.md", "06-prototype/"],
      "output": ["08-review-report-v{N}.md"],
      "confirm": true,
      "optional": true,
      "repeatable": true,
      "silent": false,
      "reviewRoles": [
        { "id": "dev-director", "name": "研发总监", "icon": "👨‍💼", "focus": "技术可行性、开发成本、工期" },
        { "id": "architect", "name": "资深架构师", "icon": "🏗️", "focus": "系统架构、技术选型、扩展性" },
        { "id": "product-director", "name": "产品总监", "icon": "📊", "focus": "产品定位、商业价值、优先级" },
        { "id": "design-director", "name": "设计总监", "icon": "🎨", "focus": "用户体验、交互设计、视觉规范" },
        { "id": "project-manager", "name": "项目经理", "icon": "📅", "focus": "项目排期、风险管理、资源协调" },
        { "id": "qa-director", "name": "QA总监", "icon": "🧪", "focus": "可测试性、验收标准、边界覆盖" },
        { "id": "security-officer", "name": "安全合规官", "icon": "🔒", "focus": "数据安全、隐私保护、合规审查" },
        { "id": "growth-officer", "name": "运营增长官", "icon": "📈", "focus": "冷启动、运营工具、数据埋点" },
        { "id": "data-analyst", "name": "数据分析师", "icon": "📉", "focus": "指标体系、埋点方案、数据质量" }
      ],
      "reviewPresets": {
        "full": { "name": "全量评审", "roles": "all", "note": "推荐企业项目" },
        "lite": { "name": "精简评审", "roles": ["dev-director", "architect", "product-director", "design-director"], "note": "适合快速迭代" },
        "security": { "name": "安全专项", "roles": ["security-officer", "qa-director"], "note": "适合敏感项目" }
      },
      "passCriteria": {
        "criticalResolved": "100%",
        "majorResolved": ">=80%",
        "noNewCritical": true
      }
    }
  ],

  "modes": {
    "standard": {
      "description": "标准模式 - 关键节点确认",
      "skipConfirm": false
    },
    "yolo": {
      "description": "快速模式 - 一路自动到 PRD 门控",
      "skipConfirm": true,
      "stopAt": ["prd", "prototype"]
    },
    "quick": {
      "description": "快速模式 - 需求 → PRD → 原型",
      "skipPhases": [],
      "skipConfirm": true,
      "stopAt": ["prd", "prototype"]
    },
    "quick-prd": {
      "description": "快速 PRD - 仅生成 PRD",
      "stopAfter": "prd"
    }
  },

  "entryPoints": {
    "default": {
      "startPhase": "reference",
      "description": "标准入口：直接描述需求"
    },
    "interview": {
      "skill": "ai-pm-interview",
      "mergeToPhase": "prd",
      "description": "现场调研入口：客户访谈 → PRD"
    },
    "data-insight": {
      "skill": "ai-pm-data",
      "mergeToPhase": "analysis",
      "description": "数据驱动入口：数据洞察 → 需求分析"
    }
  },

  "prdVersioning": {
    "strategy": "in-place",
    "description": "直接在原文档更新，不创建新版本文件",
    "trackChanges": "修订日志章节",
    "historyBackend": "git"
  },

  "outputStructure": {
    "baseDir": "output/projects/{projectName}/",
    "files": {
      "00-reference-analysis.md": "参考资料分析报告",
      "00-web-analysis/": "网页分析截图",
      "01-requirement-draft.md": "需求草案",
      "02-analysis-report.md": "需求分析报告",
      "03-competitor-report.md": "竞品研究报告",
      "04-user-stories.md": "用户故事",
      "05-prd/": "PRD 文档目录",
      "06-prototype/": "可交互原型",
      "07-references/": "参考资源",
      "08-review-report-v{N}.md": "评审报告",
      "09-analytics-requirement.md": "数据埋点需求",
      "11-field-research/": "现场调研记录（可选）"
    }
  }
}
