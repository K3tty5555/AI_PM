{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AI_PM Project Configuration Schema",
  "description": "AI_PM项目配置标准Schema，定义项目级配置的完整结构",
  "type": "object",
  "required": ["project", "workflow"],
  "properties": {
    "project": {
      "type": "object",
      "description": "项目基础信息",
      "required": ["name", "createdAt"],
      "properties": {
        "name": {
          "type": "string",
          "description": "项目名称"
        },
        "displayName": {
          "type": "string",
          "description": "项目显示名称"
        },
        "description": {
          "type": "string",
          "description": "项目一句话描述"
        },
        "createdAt": {
          "type": "string",
          "format": "date",
          "description": "创建日期"
        },
        "status": {
          "type": "string",
          "enum": ["active", "archived", "paused"],
          "description": "项目状态"
        },
        "tags": {
          "type": "array",
          "items": { "type": "string" },
          "description": "项目标签"
        }
      }
    },
    "workflow": {
      "type": "object",
      "description": "工作流配置",
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["quick", "standard", "deep", "adaptive"],
          "description": "工作流模式"
        },
        "phases": {
          "type": "object",
          "description": "各阶段配置",
          "properties": {
            "referenceAnalysis": { "$ref": "#/definitions/phaseConfig" },
            "requirementClarification": { "$ref": "#/definitions/phaseConfig" },
            "requirementAnalysis": { "$ref": "#/definitions/phaseConfig" },
            "competitorResearch": { "$ref": "#/definitions/phaseConfig" },
            "userStories": { "$ref": "#/definitions/phaseConfig" },
            "prdGeneration": { "$ref": "#/definitions/phaseConfig" },
            "prototypeGeneration": { "$ref": "#/definitions/phaseConfig" },
            "requirementReview": { "$ref": "#/definitions/phaseConfig" }
          }
        },
        "skipConfirmations": {
          "type": "boolean",
          "description": "是否跳过非关键确认",
          "default": false
        }
      }
    },
    "userProfile": {
      "type": "object",
      "description": "用户画像配置",
      "properties": {
        "level": {
          "type": "string",
          "enum": ["novice", "professional", "expert"],
          "description": "用户级别"
        },
        "role": {
          "type": "string",
          "enum": ["pm", "designer", "developer", "founder", "other"],
          "description": "用户角色"
        },
        "productType": {
          "type": "string",
          "enum": ["b2b", "b2c", "internal", "saas", "ecommerce", "social"],
          "description": "产品类型"
        },
        "industry": {
          "type": "string",
          "description": "所属行业"
        }
      }
    },
    "design": {
      "type": "object",
      "description": "设计相关配置",
      "properties": {
        "system": {
          "type": "string",
          "description": "设计规范名称"
        },
        "deviceType": {
          "type": "string",
          "enum": ["mobile", "web", "responsive"],
          "description": "设备类型"
        },
        "colorScheme": {
          "type": "string",
          "enum": ["light", "dark", "auto"],
          "description": "颜色方案"
        }
      }
    },
    "writing": {
      "type": "object",
      "description": "写作风格配置",
      "properties": {
        "style": {
          "type": "string",
          "description": "写作风格名称"
        },
        "language": {
          "type": "string",
          "enum": ["zh-CN", "zh-TW", "en"],
          "default": "zh-CN"
        }
      }
    },
    "review": {
      "type": "object",
      "description": "评审配置",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": true
        },
        "roles": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["dev", "architect", "pm", "design", "project", "qa", "security", "ops"]
          },
          "description": "启用的评审角色"
        },
        "autoFix": {
          "type": "boolean",
          "default": false,
          "description": "是否自动修复问题"
        }
      }
    },
    "integrations": {
      "type": "object",
      "description": "第三方集成配置",
      "properties": {
        "figma": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "fileUrl": { "type": "string" }
          }
        },
        "notion": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "databaseId": { "type": "string" }
          }
        }
      }
    },
    "progress": {
      "type": "object",
      "description": "项目进度状态（自动生成）",
      "properties": {
        "currentPhase": {
          "type": "string",
          "enum": ["init", "reference", "clarification", "analysis", "research", "stories", "prd", "prototype", "review", "completed"]
        },
        "completedPhases": {
          "type": "array",
          "items": { "type": "string" }
        },
        "lastModified": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "cache": {
      "type": "object",
      "description": "缓存配置",
      "properties": {
        "researchResults": {
          "type": "object",
          "properties": {
            "ttl": { "type": "number", "default": 86400 },
            "enabled": { "type": "boolean", "default": true }
          }
        },
        "webSnapshots": {
          "type": "object",
          "properties": {
            "ttl": { "type": "number", "default": 3600 },
            "enabled": { "type": "boolean", "default": true }
          }
        }
      }
    }
  },
  "definitions": {
    "phaseConfig": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": true
        },
        "skipConfirmation": {
          "type": "boolean",
          "default": false
        },
        "customPrompt": {
          "type": "string",
          "description": "自定义提示词"
        }
      }
    }
  }
}
