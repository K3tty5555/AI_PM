{
  "$schema": "./project-config-schema.json",
  "project": {
    "name": "{project-name}",
    "displayName": "{项目显示名称}",
    "description": "{项目一句话描述}",
    "createdAt": "{YYYY-MM-DD}",
    "status": "active",
    "tags": []
  },
  "workflow": {
    "mode": "adaptive",
    "phases": {
      "referenceAnalysis": {
        "enabled": true,
        "skipConfirmation": false
      },
      "requirementClarification": {
        "enabled": true,
        "skipConfirmation": false
      },
      "requirementAnalysis": {
        "enabled": true,
        "skipConfirmation": true
      },
      "competitorResearch": {
        "enabled": true,
        "skipConfirmation": true
      },
      "userStories": {
        "enabled": true,
        "skipConfirmation": true
      },
      "prdGeneration": {
        "enabled": true,
        "skipConfirmation": false
      },
      "prototypeGeneration": {
        "enabled": true,
        "skipConfirmation": false
      },
      "requirementReview": {
        "enabled": true,
        "skipConfirmation": false
      }
    },
    "skipConfirmations": false
  },
  "userProfile": {
    "level": "professional",
    "role": "pm",
    "productType": "b2b",
    "industry": ""
  },
  "design": {
    "system": null,
    "deviceType": "web",
    "colorScheme": "light"
  },
  "writing": {
    "style": "default",
    "language": "zh-CN"
  },
  "review": {
    "enabled": true,
    "roles": ["dev", "architect", "pm", "design", "project", "qa", "security", "ops"],
    "autoFix": false
  },
  "progress": {
    "currentPhase": "init",
    "completedPhases": [],
    "lastModified": ""
  },
  "cache": {
    "researchResults": {
      "ttl": 86400,
      "enabled": true
    },
    "webSnapshots": {
      "ttl": 3600,
      "enabled": true
    }
  }
}
