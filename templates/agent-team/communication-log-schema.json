{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Agent Team Communication Log Schema",
  "description": "代理间通信日志的结构定义",
  "type": "object",
  "required": ["message_id", "timestamp", "message_type", "from", "to", "project_id"],
  "properties": {
    "message_id": {
      "type": "string",
      "description": "消息唯一标识",
      "pattern": "^msg-[0-9]{6}$"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "消息发送时间"
    },
    "message_type": {
      "type": "string",
      "enum": [
        "task_assignment",
        "task_started",
        "task_progress",
        "task_completed",
        "task_blocked",
        "review_request",
        "review_response",
        "deliverable_ready",
        "information_request",
        "information_response",
        "decision_request",
        "decision_made",
        "status_update",
        "meeting_scheduled",
        "meeting_notes",
        "handoff",
        "system_event"
      ],
      "description": "消息类型"
    },
    "from": {
      "type": "string",
      "enum": ["orchestrator", "product_manager", "architect", "ui_designer", "data_analyst", "tech_writer", "user", "system"],
      "description": "发送方"
    },
    "to": {
      "type": "string",
      "enum": ["orchestrator", "product_manager", "architect", "ui_designer", "data_analyst", "tech_writer", "user", "all", "team"],
      "description": "接收方"
    },
    "project_id": {
      "type": "string",
      "description": "所属项目ID"
    },
    "task_id": {
      "type": "string",
      "description": "关联任务ID"
    },
    "content": {
      "type": "object",
      "description": "消息内容",
      "properties": {
        "subject": {
          "type": "string",
          "description": "消息主题"
        },
        "body": {
          "type": "string",
          "description": "消息正文"
        },
        "data": {
          "type": "object",
          "description": "结构化数据"
        },
        "attachments": {
          "type": "array",
          "description": "附件列表",
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string"
              },
              "path": {
                "type": "string"
              },
              "type": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "priority": {
      "type": "string",
      "enum": ["critical", "high", "medium", "low"],
      "description": "优先级"
    },
    "status": {
      "type": "string",
      "enum": ["pending", "in_progress", "completed", "blocked", "cancelled"],
      "description": "任务状态"
    },
    "response_to": {
      "type": "string",
      "description": "回复的消息ID"
    },
    "metadata": {
      "type": "object",
      "description": "附加元数据",
      "properties": {
        "phase": {
          "type": "string",
          "description": "当前项目阶段"
        },
        "duration_ms": {
          "type": "number",
          "description": "处理耗时"
        },
        "auto_generated": {
          "type": "boolean",
          "description": "是否自动生成"
        }
      }
    }
  }
}
