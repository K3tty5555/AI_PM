    "createdAt": "2026-02-28",
    "updatedAt": "2026-02-28",
    "sourceFiles": ["system-template"]
  },
  "structure": {
    "chapterOrder": [
      "一、文档概述",
      "二、需求分析",
      "三、功能清单",
      "四、产品流程",
      "五、全局说明",
      "六、详细功能设计",
      "七、效果验证",
      "八、非功能性说明"
    ],
    "requiredChapters": ["文档概述", "需求分析", "功能清单", "产品流程", "详细功能设计", "效果验证"],
    "optionalChapters": ["全局说明", "非功能性说明"],
    "tableFrequency": "high",
    "maxHeadingLevel": 4
  },
  "writing": {
    "languageStyle": "technical",
    "detailLevel": "detailed",
    "terminology": {
      "priorityTerms": ["P0", "P1", "P2"],
      "priorityDescriptions": {
        "P0": "核心功能，必须实现，影响业务流程",
        "P1": "重要功能，建议实现，提升效率",
        "P2": "增值功能，可选实现，优化体验"
      },
      "roleTerms": ["业务人员", "管理员", "系统管理员", "普通用户", "审批人", "系统"],
      "actionTerms": ["点击", "输入", "选择", "提交", "审批", "驳回", "转交", "查看", "导出", "导入"],
      "stateTerms": ["待处理", "处理中", "已通过", "已驳回", "已撤销", "已完成"]
    },
    "perspective": "business-centric"
  },
  "formatting": {
    "tableFields": {
      "revisionTable": ["日期", "修订版本", "修改描述", "涉及影响模块", "作者", "审核人", "备注"],
      "functionTable": ["模块", "功能", "子功能", "功能描述", "业务价值", "优先级", "依赖关系", "备注"],
      "detailTable": ["项目", "说明", "业务规则", "示例"],
      "metricTable": ["指标分类", "指标名称", "指标定义", "计算方式", "目标值", "监控频率"],
      "trackingTable": ["埋点事件", "触发时机", "事件参数", "业务含义", "备注"],
      "permissionTable": ["角色", "功能权限", "数据权限", "操作范围"],
      "processTable": ["步骤", "操作人", "系统动作", "业务规则", "异常处理"]
    },
    "emphasisStyle": "bold",
    "flowFormat": "table",
    "priorityMarks": ["P0", "P1", "P2"],
    "useMermaid": true
  },
  "contentFocus": {
    "userStoryWeight": "light",
    "metricsDetail": "detailed",
    "exceptionCoverage": "comprehensive",
    "technicalDetail": "moderate",
    "businessContext": "detailed",
    "permissionDesign": "detailed",
    "processDesign": "detailed"
  },
  "examples": {
    "summary": "本文档描述【功能名称】的产品需求，旨在解决【业务场景】中的【核心痛点】，通过【解决方案】实现【业务价值】，预期达到【关键指标】。",
    "requirement": "在【业务场景】下，【角色】需要【功能需求】，以解决【业务痛点】。当前通过【现有方案】处理，存在【问题描述】，导致【业务影响】。",
